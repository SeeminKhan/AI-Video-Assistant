# ─────────────────────────────────────────────────────────────────────────────
# AI Video Assistant — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# Never commit your actual .env file to version control.
#
#   cp .env.example .env
#
# ─────────────────────────────────────────────────────────────────────────────


# ── Mistral AI ────────────────────────────────────────────────────────────────
# Used by: core/summarizer.py, core/rag_engine.py, core/extractor.py
# Get your key at: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_api_key_here


# ── Sarvam AI (Hinglish transcription) ───────────────────────────────────────
# Used by: core/transcriber.py  (only when language = "hinglish")
# Get your key at: https://dashboard.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# Sarvam STT model to use (default: saaras:v2.5)
SARVAM_STT_MODEL=saaras:v2.5


# ── Whisper (local, English transcription) ────────────────────────────────────
# Used by: core/transcriber.py  (when language = "english")
# Options: tiny | base | small | medium | large
# Larger models are more accurate but slower and require more RAM/VRAM.
WHISPER_MODEL=small
